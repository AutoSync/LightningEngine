{
  "configurations": [
    {
      "name": "Windows",
      "includePath": [
        "${workspaceFolder}/**",
        "${workspaceFolder}/src/include",
        "${workspaceFolder}/interfaces",
        "${workspaceFolder}/third_party/SDL3/include",
        "${workspaceFolder}/third_party/glm/include",
        "${workspaceFolder}/third_party/Assimp/include"
      ],
      "defines": [
        "_DEBUG",
        "UNICODE",
        "_UNICODE",
        "WIN32",
        "_CONSOLE"
      ],
      "windowsSdkVersion": "10.0.22621.0",
      "compilerPath": "C:/Program Files/Microsoft Visual Studio/2022/Community/VC/Tools/MSVC/14.38.33130/bin/Hostx64/x64/cl.exe",
      "cStandard": "c17",
      "cppStandard": "c++20",
      "intelliSenseMode": "windows-msvc-x64",
      "configurationProvider": "ms-vscode.cpptools",
      "compileCommands": "${workspaceFolder}/compile_commands.json",
      "forcedInclude": [],
      "compilerArgs": [
        "/EHsc",
        "/W3",
        "/Zc:__cplusplus",
        "/std:c++20",
