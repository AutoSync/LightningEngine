{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug x64 (MSBuild)",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "\"D:\\Arquivos\\HDDR\\Microsoft\\VisualStudio\\VS26\\MSBuild\\Current\\Bin\\MSBuild.exe\" LightningEngine.sln /p:Configuration=Debug /p:Platform=x64 /m /nologo"
