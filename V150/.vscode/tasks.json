                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Build Release x64 (MSBuild)",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "\"D:\\Arquivos\\HDDR\\Microsoft\\VisualStudio\\VS26\\MSBuild\\Current\\Bin\\MSBuild.exe\" LightningEngine.sln /p:Configuration=Release /p:Platform=x64 /m /nologo"
            ],
            "group": "build",
